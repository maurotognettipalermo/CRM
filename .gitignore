db/crm.db
db/crm.db-wal
db/crm.db-shm
# Cualquier fichero de base de datos SQLite (y sus WAL/SHM)
db/*.db
db/*.db-wal
db/*.db-shm
backups/
# Logs (PM2, backup, etc.)
*.log
# Imágenes/logos de portales subidos por el usuario (datos, como la BD)
public/uploads/portales/*
!public/uploads/portales/.gitkeep
# Logos de razones sociales subidos por el usuario
public/uploads/razones-sociales/*
!public/uploads/razones-sociales/.gitkeep
# Fotos de apartamentos subidas por el usuario (datos, como la BD)
public/uploads/apartamentos/*
!public/uploads/apartamentos/.gitkeep
# Fotos de reportes de limpieza subidas por el usuario (datos, como la BD)
public/uploads/limpieza/*
!public/uploads/limpieza/.gitkeep
# Fotos de tareas de mantenimiento subidas por el usuario (datos, como la BD)
public/uploads/mantenimiento/*
!public/uploads/mantenimiento/.gitkeep
Logo/
.env
